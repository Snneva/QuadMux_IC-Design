Script TCL Magic

## Inverter

erase

# 1. N-WELL & PMOS (W = 0.5um)
box -1.6um 0.3um 1.3um 2.6um
paint nwell
box -0.55um 0.8um 0.55um 1.3um
paint pdiff

# 2. NMOS (W = 0.5um)
box -0.55um -1.3um 0.55um -0.8um
paint ndiff

# 3. POLY GATE (L = 0.15um) - Overhang > 0.25um
box -0.075um -1.6um 0.075um 1.6um
paint poly

# 4. KONTAK DIFFUSION (Digeser ke dalam aman dari licon.5a)
box -0.42um 0.965um -0.25um 1.135um
paint pdc
box 0.25um 0.965um 0.42um 1.135um
paint pdc
box -0.42um -1.135um -0.25um -0.965um
paint ndc
box 0.25um -1.135um 0.42um -0.965um
paint ndc

# 5. LOCAL INTERCONNECT (li) - Routing
box -0.5um 0.88um -0.17um 1.8um
paint li
box 0.17um 0.88um 0.5um 1.22um
paint li
box -0.5um -1.8um -0.17um -0.88um
paint li
box 0.17um -1.22um 0.5um -0.88um
paint li
box 0.17um -0.9um 0.5um 0.9um
paint li

# 6. INPUT (POLY CONTACT)
box -1.0um -0.2um -0.075um 0.2um
paint poly
box -0.85um -0.085um -0.68um 0.085um
paint pc
box -0.93um -0.165um -0.6um 0.165um
paint li

# 7. VDD & GND RAILS
box -1.3um 1.8um 1.1um 2.3um
paint li
box -1.3um -2.3um 1.1um -1.8um
paint li

# 8. TAP CONTACTS (Mencegah Latch-up)
box -1.1um 1.84um -0.68um 2.26um
paint ntap
box -0.98um 1.965um -0.81um 2.135um
paint nsc
box -1.1um -2.26um -0.68um -1.84um
paint ptap
box -0.98um -2.135um -0.81um -1.965um
paint psc

# --- SETUP PORT IN ---
box -0.93um -0.165um -0.6um 0.165um
label IN center li
select label IN
port make 1
port class input
port use signal

# --- SETUP PORT OUT ---
# (Pastikan area bersih sebelum membuat label OUT)
goto OUT
select label OUT
delete
box 0.2um -0.1um 0.5um 0.1um
label OUT center li
select label OUT
port make 2
port class output
port use signal

# --- SETUP PORT VDD ---
box -1.3um 1.8um 1.1um 2.3um
label VDD center li
select label VDD
port make 3
port class inout
port use power

# --- SETUP PORT GND ---
box -1.3um -2.3um 1.1um -1.8um
label GND center li
select label GND
port make 4
port class inout
port use ground

# --- SIMPAN & EKSTRAKSI LVS ---
save
extract all
ext2spice lvs
ext2spice subcircuit top on
ext2spice global off
ext2spice

