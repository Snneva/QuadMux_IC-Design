## Mux 2:1

erase
snap grid

# ===================================================
# 1. PLACEMENT DENGAN KOMPENSASI BOUNDING BOX
# ===================================================
box -1.6um -2.3um -1.6um -2.3um
getcell inverter_cmos
identify X_INV

box 3.4um -2.3um 3.4um -2.3um
getcell TG
identify X_TG0

box 8.4um -2.3um 8.4um -2.3um
getcell TG
identify X_TG1

# ===================================================
# 2. VDD & GND BUS POWER RAILS
# ===================================================
box -1.5um 1.8um 11.5um 2.3um; paint m1; label VDD FreeSans 20 0 0 0 center m1; port make 5
box -1.5um -2.3um 11.5um -1.8um; paint m1; label GND FreeSans 20 0 0 0 center m1; port make 6

# ===================================================
# 3. KABEL SINYAL KONTROL (JALAN LAYANG M1)
# ===================================================
box -1.5um 1.3um 11.0um 1.6um; paint m1; label SEL FreeSans 20 0 0 0 center m1; port make 3
box 0um -1.6um 11.0um -1.3um; paint m1

# ===================================================
# 4. KABEL DATA INPUT & OUTPUT 
# ===================================================
box 4.4um 0.855um 4.83um 1.145um; paint m1; label A FreeSans 20 0 0 0 center m1; port make 1
# Bus B digeser sedikit ke kanan (mulai 9.45um) agar lolos met1.2 dari kabel vertikal SEL
box 9.45um 0.855um 9.9um 1.145um; paint m1; label B FreeSans 20 0 0 0 center m1; port make 2
box 5.1um -0.15um 10.5um 0.15um; paint m1; label Y FreeSans 20 0 0 0 center m1; port make 4

# =========================================================
# 5. DISKRET VIA SQUARE (0.17um x 0.17um) UNTUK VDD & GND
# =========================================================
box -0.98um 1.965um -0.81um 2.135um; paint viali
box 4.02um 1.965um 4.19um 2.135um; paint viali
box 9.02um 1.965um 9.19um 2.135um; paint viali
box -0.98um -2.135um -0.81um -1.965um; paint viali
box 4.02um -2.135um 4.19um -1.965um; paint viali
box 9.02um -2.135um 9.19um -1.965um; paint viali

# =========================================================
# 6. INTERKONEKSI VERTIKAL (Super-Padding & Spacing)
# =========================================================
# --- JALUR SEL ---
# Turun ke Inv Vin
box -0.85um -0.085um -0.68um 0.085um; paint viali
box -0.91um -0.145um -0.62um 1.3um; paint m1

# Turun ke TG0 S_bar (Via dinaikkan ke Y=0.365um agar menjauh dari Bus Y)
box 5.77um 0.365um 5.94um 0.535um; paint viali
box 5.71um 0.305um 6.00um 1.3um; paint m1

# Turun ke TG1 S (Jumper 'li' & via digeser naik demi keamanan met1.2)
box 8.98um -0.565um 9.31um 0.615um; paint li
box 9.06um 0.365um 9.23um 0.535um; paint viali
box 9.00um 0.305um 9.29um 1.3um; paint m1

# --- JALUR net1 ---
# Naik ke Inv Vout
box 0.25um -0.085um 0.42um 0.085um; paint viali
box 0.19um -1.3um 0.48um 0.145um; paint m1

# Naik ke TG0 S (Via diturunkan ke Y=-0.365um agar aman dari Bus Y)
box 4.06um -0.535um 4.23um -0.365um; paint viali
box 4.00um -1.3um 4.29um -0.305um; paint m1

# Naik ke TG1 S_bar
box 10.77um 0.315um 10.94um 0.485um; paint viali
box 10.71um -1.3um 11.00um 0.545um; paint m1

# --- JALUR DATA (A, B, Y) ---
# Hubungkan Input A ke TG0 IN
box 4.58um 0.915um 4.75um 1.085um; paint viali
# Hubungkan Input B ke TG1 IN
box 9.58um 0.915um 9.75um 1.085um; paint viali
# Hubungkan Output Y ke TG0 OUT & TG1 OUT
box 5.25um -0.085um 5.42um 0.085um; paint viali
box 10.25um -0.085um 10.42um 0.085um; paint viali

save mux21_layout

load mux21_layout
extract do local
extract all
ext2spice lvs
ext2spice
